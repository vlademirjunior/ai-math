# Arquivo .env exemplo para o Helo CLI (AI)
# Copie este arquivo para .env e preencha com suas credenciais

# Chave de API do OpenRouter (obrigatória se usar provedor openrouter)
OPENROUTER_API_KEY=sua_chave_api_aqui
# Alternativa compatível para OpenRouter:
# OPENAI_API_KEY=sua_chave_api_aqui

# URL base do Ollama (se usar provedor ollama)
# OLLAMA_BASE_URL=http://localhost:11434

# Configurações de Modelos (opcional - sobrescreve os padrões)

# Planner
# PLANNER__PROVIDER=openrouter
# PLANNER__MODEL=stepfun/step-3.5-flash:free
# PLANNER__TEMPERATURE=0.0

# Generator
# GENERATOR__PROVIDER=openrouter
# GENERATOR__MODEL=stepfun/step-3.5-flash:free
# GENERATOR__TEMPERATURE=0.1

# Implementer
# IMPLEMENTER__PROVIDER=ollama
# IMPLEMENTER__MODEL=stepfun/step-3.5-flash:free
# IMPLEMENTER__TEMPERATURE=0.0

# Configurações Gerais
PROJECT_ROOT=.
THREAD_ID_DEFAULT=helo-ai-cli-session
SKILLS_REQUIRED=false
SKILLS_AUTOLOAD=false  # When true, auto-loads `.agents/*/SKILL.md` based on intent (e.g. “refactor”, “review”)

# LangSmith Tracing (opcional)
# ENABLE_LANGSMITH=false
# LANGSMITH_API_KEY=sua_chave_langsmith
# LANGSMITH_PROJECT=helo-ai-cli
